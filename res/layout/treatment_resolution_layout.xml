<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="ar.edu.unq.fitoscanner.activities.LoginActivity"
    tools:ignore="MergeRootFrame" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/greenLeaf"
        android:orientation="vertical" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/shapetitles"
            android:gravity="center"
            android:orientation="horizontal" >

            <TextView
                android:id="@+id/recordsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="3dp"
                android:shadowDx="1"
                android:shadowDy="1"
                android:text="MUESTRAS"
                android:textColor="@color/greenLeaf"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="5dp" >

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="5dp" >

                <Button
                    android:id="@+id/button_deleteSample"
                    style="?android:attr/buttonStyleToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/button_shape_1"
                    android:gravity="center"
                    android:padding="10dp"
                    android:shadowColor="#BFBFBF"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="5"
                    android:text="Eliminar"
                    android:textColor="#BDFFC8"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/button_send"
                    style="?android:attr/buttonStyleToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/button_shape_1"
                    android:gravity="center"
                    android:padding="10dp"
                    android:shadowColor="#BFBFBF"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="5"
                    android:text="Enviar"
                    android:textColor="#BDFFC8"
                    android:textSize="15sp" />
            </LinearLayout>
            
            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="3dp" >
                
                <TextView
                	android:id="@+id/selectSampleText"
	                android:layout_width="wrap_content"
	                android:layout_height="wrap_content"
                	android:padding="3dp"
                	android:shadowDx="1"
                	android:shadowDy="1"
                	android:text="Seleccione una muestra resuelta:"
                	android:textColor="@color/white"
                	android:textStyle="bold" />
                	
              <ScrollView
       				android:id="@+id/scrollView1"
        			android:layout_width="match_parent"
        			android:layout_height="wrap_content" >
              		  <Spinner
       				 		android:id="@+id/spinner1"
        			 		android:layout_width="match_parent"
        			 		android:layout_height="wrap_content"
        			 		style="@style/spinner_style"
        			 		android:textColor="@color/yellowFont"
        			 		android:textSize="20sp"
        			 		android:prompt="@string/spinner_prompt" />
        	  </ScrollView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:padding="5dp" >

                <ListView
                    android:id="@+id/savedSamplesList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>