<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="ar.edu.unq.fitoscanner.activities.LoginActivity"
    tools:ignore="MergeRootFrame" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/greenLeaf"
        android:orientation="vertical" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/shapetitles"
            android:gravity="center"
            android:orientation="horizontal" >

            <TextView
                android:id="@+id/recordsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="3dp"
                android:shadowDx="1"
                android:shadowDy="1"
                android:text="RESOLUCIÓN DE MUESTRA"
                android:textColor="@color/greenLeaf"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
        
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="5dp" >

           
           
       		
            <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="left"
            android:gravity="left" >

            <TextView
                android:id="@+id/specieName_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:padding="5dp"
                android:text="Nombre:"
                android:textColor="@color/yellowFont" />

            <TextView
                android:id="@+id/specieName_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ems="10"
                android:focusable="false"
                android:inputType="text"
                android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
             android:layout_gravity="left"
            android:gravity="left" >

            <TextView
                android:id="@+id/specieScientificName_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:padding="5dp"
                android:text="Nombre científico:"
                android:textColor="@color/yellowFont" />

            <TextView
                android:id="@+id/specieScientificName_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ems="10"
                android:focusable="false"
                android:inputType="text" 
                android:textColor="@color/white"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
             android:layout_gravity="left"
            android:gravity="left" >

            <TextView
                android:id="@+id/specieDescription_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:padding="5dp"
                android:text="Breve descripción: "
                android:textColor="@color/yellowFont" />
		
        </LinearLayout>
        
        <ScrollView
       				android:id="@+id/scrollView1"
        			android:layout_width="wrap_content"
        			android:layout_height="120dip" >
            <TextView
                android:id="@+id/specieDescription_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"/>
         </ScrollView>

        </LinearLayout>
	 
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center">
    			<TextView
			        android:id="@+id/textView2"
			        android:layout_alignParentTop="true"
			        android:layout_width="wrap_content"
			        android:layout_height="wrap_content"
			        android:text="Imágenes de la especie"
			        android:textColor="@color/white"
			        android:layout_centerHorizontal="true">
    			</TextView>
   			 <ScrollView
       				android:id="@+id/scrollView1"
        			android:layout_width="match_parent"
        			android:layout_height="wrap_content"
        			android:layout_alignParentBottom="true" 
        			android:padding="3dp" >
              		  
              		  <Spinner
       				 		android:id="@+id/spinner1"
        			 		android:layout_width="match_parent"
        			 		android:layout_height="wrap_content"
        			 		style="@style/spinner_style"
        			 		android:textColor="@color/yellowFont"
        			 		android:textSize="20sp"
        			 		android:prompt="@string/spinner_prompt" 
        			 		android:padding="3dp"
        			 		/>
        	  </ScrollView>
    
				
                <ListView
                    android:id="@+id/specieImagesList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/textView2"
        			android:layout_above="@+id/scrollView1"
        			android:padding="3dp"
                     />
                    
             
            </RelativeLayout>
            
            <LinearLayout
                android:id="@+id/spinnerSection"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="3dp" >
                
                	
              
            </LinearLayout>
        </LinearLayout>

</FrameLayout>