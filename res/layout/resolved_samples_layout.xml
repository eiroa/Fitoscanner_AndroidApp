<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="ar.edu.unq.fitoscanner.activities.LoginActivity"
    tools:ignore="MergeRootFrame" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/greenLeaf"
        android:orientation="vertical" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/shapetitles"
            android:gravity="center"
            android:orientation="horizontal" >

            <TextView
                android:id="@+id/recordsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="3dp"
                android:shadowDx="1"
                android:shadowDy="1"
                android:text="MUESTRAS RESUELTAS"
                android:textColor="@color/greenLeaf"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
        
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="2dp" >

            <LinearLayout
            	android:id="@+id/sampleActionButtons_layout"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="3dp" >

                <Button
                    android:id="@+id/button_deleteSample"
                    style="?android:attr/buttonStyleToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/selector_button_level"
                    android:gravity="center"
                    android:padding="10dp"
                    android:shadowColor="#BFBFBF"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="5"
                    android:text="Eliminar"
                    android:textColor="#BDFFC8"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/button_open_resolution"
                    style="?android:attr/buttonStyleToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/selector_button_level"
                    android:gravity="center"
                    android:padding="12dp"
                    android:shadowColor="#BFBFBF"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="5"
                    android:text="Ver resolución de la muestra"
                    android:textColor="#F9E279"
                    android:textSize="16sp" />
            </LinearLayout>
            
            <LinearLayout
                android:id="@+id/spinnerSection"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="2dp" >
                
                <TextView
                	android:id="@+id/selectSampleText"
	                android:layout_width="wrap_content"
	                android:layout_height="wrap_content"
                	android:padding="2dp"
                	android:shadowDx="1"
                	android:shadowDy="1"
                	android:text="Seleccione una muestra resuelta:"
                	android:textColor="@color/white"
                	android:textStyle="bold" />
                	
              <ScrollView
       				android:id="@+id/scrollView1"
        			android:layout_width="match_parent"
        			android:layout_height="wrap_content" >
              		  <Spinner
       				 		android:id="@+id/spinner1"
        			 		android:layout_width="match_parent"
        			 		android:layout_height="wrap_content"
        			 		style="@style/spinner_style"
        			 		android:textColor="@color/yellowFont"
        			 		android:textSize="20sp"
        			 		android:prompt="@string/spinner_prompt" />
        	  </ScrollView>
            </LinearLayout>
            
             <LinearLayout
            	    android:layout_width="match_parent"
            		android:layout_height="match_parent"
            		android:orientation="vertical"
            		weigthSum="10">	  
            				
            		<ScrollView
		        			android:layout_width="match_parent"
		        			android:layout_height="0dp"
		        			android:layout_weight="7" 
		        			android:fillViewport="true"
		        			>		
            			<LinearLayout
					            android:layout_width="wrap_content"
					            android:layout_height="match_parent"
					            android:gravity="center"
            					android:orientation="vertical"
					            >	
				            <LinearLayout
					            android:layout_width="wrap_content"
					            android:layout_height="match_parent"
					            android:layout_gravity="left"
					            android:gravity="left" 
					            android:padding="3dp">
				
					            <TextView
					                android:id="@+id/savedSample_sampleNameLabel"
					                android:layout_width="wrap_content"
					                android:layout_height="match_parent"
					                android:focusable="false"
					                android:padding="1dp"
					                android:text="Muestra:"
					                android:textColor="@color/yellowFont" />
					
					            <TextView
					                android:id="@+id/savedSample_sampleName"
					                android:layout_width="wrap_content"
					                android:layout_height="match_parent"
					                android:layout_weight="1"
					                android:ems="11"
					                android:focusable="false"
					                android:inputType="text"
					                android:textColor="@color/white" />
				        	</LinearLayout>
				
				        	<LinearLayout
					            android:layout_width="wrap_content"
					            android:layout_height="match_parent"
					            android:layout_gravity="left"
					            android:gravity="left" >
				
					            <TextView
					                android:id="@+id/savedSample_latAndLonLabel"
					                android:layout_width="wrap_content"
					                android:layout_height="match_parent"
					                android:focusable="false"
					                android:padding="2dp"
					                android:text="Latitud y longitud:"
					                android:textColor="@color/yellowFont" />
					
					            <TextView
					                android:id="@+id/savedSample_latAndLon"
					                android:layout_width="wrap_content"
					                android:layout_height="match_parent"
					                android:ems="11"
					                android:focusable="false"
					                android:inputType="text" 
					                android:textColor="@color/white"/>
				        	</LinearLayout>
				
				        	<LinearLayout
					            android:layout_width="wrap_content"
					            android:layout_height="match_parent"
					            android:layout_gravity="left"
					            android:gravity="left" >
				
					            <TextView
					                android:id="@+id/savedSample_cityLabel"
					                android:layout_width="wrap_content"
					                android:layout_height="match_parent"
					                android:focusable="false"
					                android:padding="2dp"
					                android:text="Localidad: "
					                android:textColor="@color/yellowFont" />
					
					            <TextView
					                android:id="@+id/savedSample_city"
					                android:layout_width="wrap_content"
					                android:layout_height="match_parent"
					                android:ems="11"
					                android:focusable="false"
					                android:inputType="text" 
					                android:textColor="@color/white"/>
				        	</LinearLayout>
				        
				        	<LinearLayout
					            android:layout_width="wrap_content"
					            android:layout_height="match_parent"
					            android:layout_gravity="left"
					            android:gravity="left" >
				
					            <TextView
					                android:id="@+id/savedSample_stateLabel"
					                android:layout_width="wrap_content"
					                android:layout_height="match_parent"
					                android:focusable="false"
					                android:padding="2dp"
					                android:text="Región: "
					                android:textColor="@color/yellowFont" />
					
					            <TextView
					                android:id="@+id/savedSample_state"
					                android:layout_width="wrap_content"
					                android:layout_height="match_parent"
					                android:ems="11"
					                android:focusable="false"
					                android:inputType="text" 
					                android:textColor="@color/white"/>
				        	</LinearLayout>
				
				        	<LinearLayout
				            	android:layout_width="wrap_content"
				            	android:layout_height="match_parent"
				             	android:layout_gravity="left"
				            	android:gravity="left" >
				
					            <TextView
					                android:id="@+id/savedSample_countryLabel"
					                android:layout_width="wrap_content"
					                android:layout_height="match_parent"
					                android:focusable="false"
					                android:padding="2dp"
					                android:text="País:"
					                android:textColor="@color/yellowFont" />
					
					            <TextView
					                android:id="@+id/savedSample_country"
					                android:layout_width="wrap_content"
					                android:layout_height="match_parent"
					                android:focusable="false"
					                android:inputType="text" 
					                android:textColor="@color/white"/>
				        	</LinearLayout>
				
				        	<LinearLayout
				            	android:layout_width="wrap_content"
				            	android:layout_height="match_parent"
				            	android:layout_gravity="center_horizontal"
				            	android:padding="3dp">
				
					            <TextView
					                android:id="@+id/savedSample_originDateLabel"
					                android:layout_width="wrap_content"
					                android:layout_height="match_parent"
					                android:focusable="false"
					                android:padding="1dp"
					                android:text="Fecha:"
					                android:textColor="@color/yellowFont" />
					
					            <TextView
					                android:id="@+id/savedSample_originDate"
					                android:layout_width="wrap_content"
					                android:layout_height="match_parent"
					                android:focusable="false"
					                android:text="Date"
					                android:textSize="13dp" 
					                android:textColor="@color/white"/>
				        	</LinearLayout>
				        
				       		 <LinearLayout
				           	 	android:layout_width="wrap_content"
				            	android:layout_height="match_parent"
				            	android:layout_gravity="center_horizontal">
				
					            <TextView
					                android:id="@+id/savedSample_noGPSDataLabel"
					                android:layout_width="wrap_content"
					                android:layout_height="match_parent"
					                android:focusable="false"
					                android:text="Sin datos de gps"
					                android:textSize="13dp" 
					                android:textColor="@color/white"/>
				        	</LinearLayout>
		        	  </LinearLayout>
		        	 </ScrollView>
		        	
		
		            <LinearLayout
		                android:layout_width="match_parent"
		                android:layout_height="0dp"
		                android:layout_weight="15"
		                android:layout_gravity="center_horizontal"
		                android:gravity="center"
		                android:padding="2dp" 
		                >
		
		                <ListView
		                    android:id="@+id/savedSampleImagesList"
		                    android:layout_width="match_parent"
		                    android:layout_height="match_parent"
		                    />
		            </LinearLayout>
            </LinearLayout>
            
        </LinearLayout>
        
    </LinearLayout>

</FrameLayout>